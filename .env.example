# ============================================================
# Variables de entorno - Solutech Cloud
# ============================================================
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA commitees .env.local al repositorio.
# ============================================================

# --- Formspree (formulario de contacto) ---
# Crear cuenta en: https://formspree.io/
# Plan gratis: 50 envíos/mes
# Ir a "New form" y copiar el endpoint (ej: https://formspree.io/f/xyzabc123)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/TU_FORM_ID

# --- Cloudflare Turnstile (anti-spam) ---
# Crear widget en: https://dash.cloudflare.com → Turnstile
# Agregar dominio solutechcloud.com
# Copiar "Site Key" (pública, va en frontend)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAATU_SITE_KEY

# La Secret Key de Turnstile NO se usa en este setup (validación del lado de
# Formspree con su integración nativa). Si en el futuro montas tu propio
# endpoint de validación server-side, la guardas como TURNSTILE_SECRET_KEY
# sin el prefijo NEXT_PUBLIC_.
